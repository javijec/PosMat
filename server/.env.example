PORT=4000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=cambia-esto-por-un-secreto-seguro
JWT_EXPIRES_IN=7d
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/posmat?schema=public"
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Firebase Admin
# Opción 1 (recomendado): ruta local al JSON de credenciales
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=/ruta/al/serviceAccountKey.json
# Opción 2: JSON directamente (una línea, escapado)
# FIREBASE_SERVICE_ACCOUNT_KEY_JSON='{"type":"...","project_id":"..."}'
